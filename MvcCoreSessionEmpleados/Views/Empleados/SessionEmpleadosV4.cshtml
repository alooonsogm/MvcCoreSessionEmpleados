@model List<Empleado>

<h1 style="color:blue">Session Empleados V4</h1>

<p>
    <a asp-controller="Empleados" asp-action="EmpleadosAlmacenadoV4">Mostrar Empleados Almacenado v4</a>
</p>

<h4 style="color:blue">@ViewData["MENSAJE"]</h4>

@if (Model != null)
{
    <ul class="list-group">
        @foreach (Empleado empleado in Model)
        {
            <li class="list-group-item list-group-item-warning">
                @empleado.Apellido
                <a asp-controller="Empleados" asp-action="SessionEmpleadosV4" asp-route-idEmpleado="@empleado.IdEmpleado" class="btn btn-warning">Almacenar Empleado</a>
            </li>
        }
    </ul>
}