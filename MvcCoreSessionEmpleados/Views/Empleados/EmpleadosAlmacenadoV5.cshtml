@model List<Empleado>

<h1 style="color:green">Empleados almacenados session v5</h1>

<p>
    <a asp-controller="Empleados" asp-action="SessionEmpleadosV5">Volver a session empleados</a>
</p>

@if (Context.Session.GetString("IDSEMPLEADOSV5") == null)
{
    <h2 style="color:orange">
        No existen empleados en session.
    </h2>
}

@if (Model != null)
{
    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Apellido</th>
                <th>Oficio</th>
                <th>Salario</th>
                <th>Id Departamento</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (Empleado emp in Model)
            {
                <tr>
                    <td>@emp.IdEmpleado</td>
                    <td>@emp.Apellido</td>
                    <td>@emp.Oficio</td>
                    <td>@emp.Salario</td>
                    <td>@emp.IdDepartamento</td>
                    <td>
                        <a asp-controller="Empleados" asp-action="EmpleadosAlmacenadoV5" asp-route-idEliminar="@emp.IdEmpleado" class="btn btn-danger">Eliminar Session</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}